}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 4px 0 4px;
}
QLineEdit {
    min-height: 30px;
    border: 1px solid #b9c4d0;
    border-radius: 6px;
    padding: 4px 8px;
    background-color: #ffffff;
}
QPushButton {
    min-height: 32px;
    border-radius: 6px;
    padding: 6px 12px;
    background-color: #e8eef5;
    border: 1px solid #b9c4d0;
}
QPushButton:hover {
    background-color: #dce6f2;
}
QPushButton#botao_autorizar_download {
    background-color: #2d89ef;
    color: white;
    font-weight: bold;
    border: 1px solid #1f6fca;
}
QPushButton#botao_autorizar_download:hover {
    background-color: #2277d1;
}
QLabel#label_titulo {
    font-size: 18px;
    font-weight: bold;
    color: #1f2937;
}
QLabel#label_subtitulo {
    color: #4b5563;
}
QLabel#label_status {
    color: #374151;
    background-color: #eef3f8;
    border: 1px solid #d6dee8;
    border-radius: 6px;
    padding: 8px;
}
QProgressBar {
    border: 1px solid #c8d2de;
    border-radius: 6px;
    text-align: center;
    min-height: 24px;
    background-color: #ffffff;
}
QProgressBar::chunk {
    background-color: #2d89ef;
    border-radius: 5px;
}</string>
